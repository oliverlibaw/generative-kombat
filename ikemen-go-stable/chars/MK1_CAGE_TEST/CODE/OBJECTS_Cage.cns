;-------------------------------------------------------------------
;BLOOD SPLAT 1 & 2
[Statedef 8000]
type = S
movetype = I
physics = N
anim = ifelse(ishelper(8000),1020,1021)

[State 1000, 3]
type = SprPriority
trigger1 = 1
value = 30

[State ]
type = velset
trigger1 = 1
y = 0
x = 0

[State ]
type = assertspecial
trigger1 = 1
flag = noshadow

[State end]
type = Destroyself
trigger1 = animtime = 0

;-------------------------------------------------------------
;BLOOD BATH L
[Statedef 8010]
type    = A
movetype= I
physics = N
velset = 0,0
ctrl = 0
sprpriority = 3

[State y]
type = VarRandom
trigger1 = 1
v = 0
range = -3,-6
[State x]
type = VarRandom
trigger1 = 1
v = 1
range = -1,-4

[State ]
type = velset
trigger1 = time = 1
y = var(0)
x = var(1)

[State end]
type = changeanim
trigger1 = time = 0
value = 1017

[State ]
type = veladd
trigger1 = time >= 3
y = .1

[State ]
type = veladd
trigger1 = time >= 10
y = .2

[State ]
type = assertspecial
trigger1 = 1
flag = noshadow

[State 1000, 3]
type = SprPriority
trigger1 = 1
value = 20

[State end]
type = changestate
triggerall = time >= 5
trigger1 = (Vel Y > 0)&&(Pos Y >= 0)
value = 8012

;-------------------------------------------------------------
;BLOOD BATH R
[Statedef 8011]
type    = A
movetype= I
physics = N
velset = 0,0
ctrl = 0
sprpriority = 3

[State 1000, 3]
type = SprPriority
trigger1 = 1
value = 20

[State y]
type = VarRandom
trigger1 = 1
v = 0
range = -3,-6
[State x]
type = VarRandom
trigger1 = 1
v = 1
range = 1,4

[State ]
type = velset
trigger1 = time = 1
y = var(0)
x = var(1)

[State end]
type = changeanim
trigger1 = time = 0
value = 1018

[State ]
type = veladd
trigger1 = time >= 3
y = .1

[State ]
type = veladd
trigger1 = time >= 10
y = .2

[State ]
type = assertspecial
trigger1 = 1
flag = noshadow

[State end]
type = changestate
triggerall = time >= 5
trigger1 = (Vel Y > 0)&&(Pos Y >= 0)
value = 8012
;****************************************************************
;END BLOOD
[Statedef 8012]
type    = A
movetype= I
physics = N
ctrl = 0
anim = 1019
sprpriority = 3

[State 7, Blood_sound]
type = PlaySnd
trigger1 = root,var(25) = 1
trigger1 = animelem = 1
value = S10,ifelse(random<=500,2,ifelse(random>500,3,5))
volumescale = 90

[State 7, blood_sound]
type = PlaySnd
trigger1 = root,var(25) = 0
trigger1 = animelem = 1
value = S10,ifelse(random<=500,6,ifelse(random>500,7,8))
volumescale = 90

[State ]
type = velset
trigger1 = 1
y = 0
x = 0

[State ]
type = posset
trigger1 = 1
y = 6

[State ]
type = assertspecial
trigger1 = 1
flag = noshadow

[State end]
type = destroyself
trigger1 = time = 35

;---------------------------------------------------------------------------
;BLOOD FLOOR
[Statedef 1023]
type    = S
movetype= H
physics = N
velset = 0,0
ctrl = 0
anim = 9999

[State 5030, 2]
type = PosSet
trigger1 = 1
x = (enemy,pos x+1)
y = 0

[State 5030, 2]
type = VelSet
trigger1 = 1
x = 0
y = 0

[State 5030, 4]
type = Changestate
triggerall = 1
trigger1 = RoundState = 4
trigger2 = Root,Stateno = [180,182]
Value = 1024

;---------------------------------------------------------------------------
;BLOOD FLOOR APPEAR
[Statedef 1024]
type    = S
movetype= H
physics = N
velset = 0,0
ctrl = 0
anim = 1023

[State 1007, Finish]
type = AngleDraw
trigger1 = time = 0
value = 0
scale = 1,1

[State 5, 0]
type = AngleDraw
trigger1 = time >0
value = 0
scale = FVar(14) * Const(size.xscale), 1.2

[State -2, VarAdd]
type = Varset
trigger1 = time = 0
ignorehitpause = 1
fv = 14
value = 0.4

[State 7010, 3]
type = SprPriority
trigger1 = 1
value = -40 

[State -2, VarAdd]
type = Varadd 
trigger1 = time >0
ignorehitpause = 1
fv = 14
value = 0.004

[State 5030, 2]
type = VelSet
trigger1 = 1
x = 0
y = 0

[State 5030, 4]
type = Destroyself
trigger1 = time > 10000
trigger2 = 1
trigger2 = Roundstate <=1










































