triggerall = animtime = 0
trigger1 = var(2) >= 1
value = 201
[State end]
type = changestate
triggerall = animtime = 0
trigger1 = var(3) >= 1
value = 203

[State 0, 1]
type = VarSet
trigger1 = time<=1
v = 7
value = 0

[State 0, 1]
type = VarSet
trigger1 = p2Statetype != A
trigger1 = movecontact
trigger1 = animelemtime(3)=3
v = 7
value = 1

[State end]
type = changestate
trigger1 = var(7) = 1
trigger1 = var(50) = 1
