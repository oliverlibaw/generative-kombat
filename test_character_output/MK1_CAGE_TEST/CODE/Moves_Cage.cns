[State 300, 5]
type = movehitreset
Trigger1 = time = 0

[State -2, Low_High_Punches]
Type = VarRangeSet
trigger1 = time <= 0
Value = 0
First = 2
Last = 3

[State 0, 1]
type = Varadd
trigger1 = p2Statetype = A
trigger1 = movecontact
trigger1 = animelemtime(3)=3
v = 0
value = 2

[State 0, 1]
type = Varadd
trigger1 = p2Statetype != A
trigger1 = movecontact
trigger1 = animelemtime(3)=3
v = 1
value = 100

[State 0, 1]
type = Varset
trigger1 = var(50) = 0
trigger1 = time >1
trigger1 = command = "x"
v = 2
value = 1
[State 0, 1]
type = Varset
trigger1 = var(50) = 0
trigger1 = var(2) = 0
trigger1 = time >1
trigger1 = command = "y"
v = 3
value = 1

