;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------

[Statedef -2]

[State 183, 1]
type = AssertSpecial
trigger1 = P2stateno = [500,700]
trigger1 = 1
flag = timerfreeze
ignorehitpause = 1

[State -2, Guarding]
type = AssertSpecial
trigger1 = 1
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard
ignorehitpause = 1

[State -2, NO SLOW]
type = AssertSpecial
trigger1 = 1
ignorehitpause = 1
flag = nokoslow
ignorehitpause = 1

[State -2, VAR]
type = AssertSpecial
trigger1 = var(28) = 1
trigger1 = 1
flag = Nomusic
ignorehitpause = 1

[State -2, VAR]
type = AssertSpecial
trigger1 = var(28) = 1
trigger1 = 1
flag = NoBarDisplay
ignorehitpause = 1


