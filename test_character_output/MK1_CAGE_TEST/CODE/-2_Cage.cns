;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]

[State -3,Display.de.Tela]
type = DisplayToClipboard
trigger1 = var(17) >= 1
text = "Var(17)=%d, var 17 activada"
Params = var(17)
[State -3,Display.de.Tela]
type = DisplayToClipboard
trigger1 = var(17) <= 0
text = "Var(17)=%d, var 17 desactivada"
params = var(17)
